# --- Default chat model (all roles unless overridden below) ---
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o-mini

# Optional: different providers per role (empty = use defaults above)
# LLM_PROVIDER_RESEARCH=openai
# LLM_MODEL_RESEARCH=gpt-4o-mini
# LLM_PROVIDER_PRO=claude
# LLM_MODEL_PRO=claude-sonnet-4-20250514
# LLM_PROVIDER_AGAINST=deepseek
# LLM_MODEL_AGAINST=deepseek-chat
# LLM_PROVIDER_JUDGE=ollama
# LLM_MODEL_JUDGE=llama3.2

# --- API keys (set what you use) ---
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
DEEPSEEK_API_KEY=

# Ollama (local)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_FALLBACK_MODEL=llama3.2

# --- Research tools (at least one recommended) ---
TAVILY_API_KEY=
SERPAPI_API_KEY=
# Alternative name used in some setups:
SERPER_API_KEY=
NEWS_API_KEY=

# --- Gradio ---
GRADIO_SERVER_NAME=127.0.0.1
GRADIO_SERVER_PORT=7860
GRADIO_SHARE=false
